{
  "info": {
    "_postman_id": "d87f4d96-78d4-4d62-972a-1d4645b0418f",
    "name": "News API",
    "description": "Session-based CRUD flow using Spring Security 7 SPA CSRF protection. Run Login first, followed by the CRUD requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "username",
      "value": "editor"
    },
    {
      "key": "password",
      "value": "editor123",
      "type": "secret"
    },
    {
      "key": "csrfToken",
      "value": ""
    },
    {
      "key": "newsId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "protocolProfileBehavior": {
            "followRedirects": false
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "The pre-request script obtains the login CSRF token. After authentication, the response script captures the new XSRF-TOKEN for protected CRUD requests."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({",
                  "    url: pm.collectionVariables.get('baseUrl') + '/login',",
                  "    method: 'GET',",
                  "    header: { Cookie: 'XSRF-TOKEN=' }",
                  "}, function (error, response) {",
                  "    if (error) {",
                  "        throw error;",
                  "    }",
                  "",
                  "    const setCookieHeaders = response.headers.all()",
                  "        .filter(header => String(header.key || header.name).toLowerCase() === 'set-cookie')",
                  "        .map(header => header.value);",
                  "    const directHeader = response.headers.get('Set-Cookie');",
                  "    if (directHeader) {",
                  "        setCookieHeaders.push(directHeader);",
                  "    }",
                  "    const xsrfMatch = setCookieHeaders.join('\\n').match(/XSRF-TOKEN=([^;]+)/);",
                  "",
                  "    if (!xsrfMatch) {",
                  "        throw new Error('Login page did not return an XSRF-TOKEN cookie');",
                  "    }",
                  "",
                  "    const rawToken = xsrfMatch[1];",
                  "    const token = decodeURIComponent(rawToken);",
                  "    pm.request.headers.upsert({ key: 'X-XSRF-TOKEN', value: token });",
                  "    pm.request.headers.upsert({ key: 'Cookie', value: 'XSRF-TOKEN=' + rawToken });",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login redirects after authentication', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([302, 303]);",
                  "});",
                  "",
                  "const setCookies = pm.response.headers.all()",
                  "    .filter(header => String(header.key || header.name).toLowerCase() === 'set-cookie')",
                  "    .map(header => header.value);",
                  "const directSetCookie = pm.response.headers.get('Set-Cookie');",
                  "if (directSetCookie) {",
                  "    setCookies.push(directSetCookie);",
                  "}",
                  "const xsrfTokens = setCookies",
                  "    .map(value => value.match(/XSRF-TOKEN=([^;]*)/))",
                  "    .filter(match => match && match[1])",
                  "    .map(match => decodeURIComponent(match[1]));",
                  "const csrfToken = xsrfTokens.at(-1);",
                  "",
                  "pm.test('Post-login XSRF-TOKEN is present', function () {",
                  "    pm.expect(csrfToken, 'XSRF-TOKEN from Set-Cookie').to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "if (csrfToken) {",
                  "    pm.collectionVariables.set('csrfToken', csrfToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Logout",
          "protocolProfileBehavior": {
            "followRedirects": false
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-XSRF-TOKEN",
                "value": "{{csrfToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "logout"
              ]
            },
            "description": "Invalidates the authenticated session. Run this after the CRUD requests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logout redirects to the login page', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([302, 303]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "News CRUD",
      "item": [
        {
          "name": "List News",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/news?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "news"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('News page is returned', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get News by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/news/{{newsId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "news",
                "{{newsId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('News item is returned', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Create News",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-XSRF-TOKEN",
                "value": "{{csrfToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman news\",\n  \"details\": \"Created through the Postman collection\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/news",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "news"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('News is created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('newsId', String(body.newsId));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Update News",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-XSRF-TOKEN",
                "value": "{{csrfToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Postman news\",\n  \"details\": \"Updated through the Postman collection\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/news/{{newsId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "news",
                "{{newsId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('News is updated', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Delete News",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-XSRF-TOKEN",
                "value": "{{csrfToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/news/{{newsId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "news",
                "{{newsId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('News is deleted', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    }
  ]
}
